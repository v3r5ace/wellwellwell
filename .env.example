# Storage
WELL_DATA_DIR=./data
WELL_DB_PATH=./data/wellwellwell.sqlite3
WELL_SNAPSHOTS_DIR=./data/snapshots

# API
WELL_BIND_HOST=0.0.0.0
WELL_BIND_PORT=8000

# Built-in collector loop
WELL_ENABLE_COLLECTOR=false
WELL_COLLECT_INTERVAL_MINUTES=60
WELL_COLLECT_START_HOUR=8
WELL_COLLECT_END_HOUR=20
WELL_COLLECT_ON_STARTUP=true

# Camera ingest
# Use one of these:
CAMERA_SNAPSHOT_URL=
# Example Protect secure RTSP URL:
# CAMERA_RTSP_URL=rtsps://protect-host-or-ip:7441/your-stream-token?enableSrtp
CAMERA_RTSP_URL=
CAMERA_USERNAME=
CAMERA_PASSWORD=
FFMPEG_PATH=ffmpeg
FFMPEG_RTSP_TRANSPORT=tcp
FFMPEG_CAPTURE_TIMEOUT_SECONDS=25

# Region of interest around the cable and marker
# Format: x,y,width,height
WELL_CROP=1450,0,250,580

# Marker detection tuning in HSV (default: pink marker)
WELL_MARKER_HSV_LOWER=140,80,100
WELL_MARKER_HSV_UPPER=175,255,255
WELL_MIN_CONTOUR_AREA=80

# Optional: expected x position of the marker within the cropped ROI
# Leave blank to use the center of the crop.
WELL_EXPECTED_MARKER_X=

# Calibration
WELL_EMPTY_Y=66
WELL_FULL_Y=484
WELL_FULL_GALLONS=7500

# Diagnostics
WELL_SAVE_DEBUG_IMAGES=true

# Admin actions
WELL_FLUSH_PASSWORD=
