# Storage
WELL_DATA_DIR=./data
WELL_DB_PATH=./data/wellwellwell.sqlite3
WELL_SNAPSHOTS_DIR=./data/snapshots

# API
WELL_BIND_HOST=0.0.0.0
WELL_BIND_PORT=8000

# Built-in collector loop
WELL_ENABLE_COLLECTOR=false
WELL_COLLECT_INTERVAL_MINUTES=15
WELL_COLLECT_ON_STARTUP=true

# Camera ingest
# Use one of these:
CAMERA_SNAPSHOT_URL=
# Example Protect secure RTSP URL:
# CAMERA_RTSP_URL=rtsps://protect-host-or-ip:7441/your-stream-token?enableSrtp
CAMERA_RTSP_URL=
CAMERA_USERNAME=
CAMERA_PASSWORD=
FFMPEG_PATH=ffmpeg
FFMPEG_RTSP_TRANSPORT=tcp
FFMPEG_CAPTURE_TIMEOUT_SECONDS=25

# Region of interest around the cable and blue weight
# Format: x,y,width,height
WELL_CROP=1450,0,250,580

# Blue marker detection tuning in HSV
WELL_BLUE_HSV_LOWER=90,60,40
WELL_BLUE_HSV_UPPER=140,255,255
WELL_MIN_CONTOUR_AREA=80

# Optional: expected x position of the blue marker within the cropped ROI
# Leave blank to use the center of the crop.
WELL_EXPECTED_MARKER_X=

# Calibration
WELL_EMPTY_Y=190
WELL_FULL_Y=510
WELL_FULL_GALLONS=7500

# Diagnostics
WELL_SAVE_DEBUG_IMAGES=true

# Admin actions
WELL_FLUSH_PASSWORD=
